generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  ANALYSIS
  APPROVED
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum ProjectRisk {
  LOW
  MEDIUM
  HIGH
}

model Project {
  id          String        @id @default(uuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  totalBudget Decimal       @db.Decimal(14, 2)
  description String
  status      ProjectStatus @default(ANALYSIS)
  risk        ProjectRisk
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
